# Godot auto-generated files
.gen.*
.godot/
!project/.godot/
*.import

# Development project build output; its manifest is tracked.
project/.godot/*
!project/.godot/extension_list.cfg
project/lib/

# Legacy generated output from the pre-project/addon layout.
addons/

# Zig build
.zig-cache/
zig-out/
zig-pkg/

# Compile commands
compile_commands.json

# Object/library files
*.o
*.os
*.obj
*.bc
*.pyc
*.dblite
*.pdb
*.lib
*.exp

# IDE
.vscode/*
!.vscode/extensions.json
.DS_Store
.idea/

# Other
*.log
*.config
*.creator
*.creator.user
*.files
*.includes
*.idb
